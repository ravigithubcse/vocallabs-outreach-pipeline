# ============================================================
# VOCALLABS OUTREACH PIPELINE — ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your real API keys.
# Never commit .env to version control.

# --- Stage 1: Ocean.io ---
# Sign up at ocean.io using your company email (domain must exist first)
OCEAN_API_KEY=your_ocean_io_api_key_here

# --- Stage 2: Prospeo ---
# Get your API key at app.prospeo.io/api
PROSPEO_API_KEY=your_prospeo_api_key_here

# --- Stage 3: Eazyreach ---
# Create account at eazyreach.app (credits provided by Vocallabs)
EAZYREACH_API_KEY=your_eazyreach_api_key_here

# --- Stage 4: Brevo (formerly Sendinblue) ---
# Get your API key at app.brevo.com → Settings → API Keys
BREVO_API_KEY=your_brevo_api_key_here

# --- Sender Identity (must be verified in Brevo) ---
# This should be your company domain email (e.g., you@yourdomain.com)
SENDER_EMAIL=you@yourdomain.com
SENDER_NAME=Your Name

# --- Pipeline Config ---
# Max lookalike companies to fetch from Ocean.io (default: 10)
MAX_LOOKALIKES=10

# Max decision-makers per company from Prospeo (default: 3)
MAX_PROSPECTS_PER_COMPANY=3

# Delay between API calls in ms to respect rate limits (default: 1000)
API_DELAY_MS=1000
